{
  "name": "dataloom",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "cd server && ./.venv/bin/uvicorn main:app --reload --port 3001",
    "start": "concurrently -n api,web -c blue,green \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "lucide-react": "0.563.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0",
    "vite": "^6.4.0"
  }
}
